NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# e.g. your-project.appspot.com — required for venue photo uploads
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App URL (payment redirects) — e.g. https://your-cms.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Owner login OTP email (https://resend.com — free tier works for dev)
RESEND_API_KEY=
OWNER_OTP_FROM_EMAIL=Swing Play <onboarding@resend.dev>
# Optional pepper for OTP hashing in production
OWNER_OTP_SECRET=

# Firebase Admin — values from service account JSON (not JS code)
# project_id → FIREBASE_PROJECT_ID | client_email → FIREBASE_CLIENT_EMAIL | private_key → FIREBASE_PRIVATE_KEY
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or paste whole JSON on one line: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# PhonePe Standard Checkout v2 (Developer Settings on business.phonepe.com)
# Set PHONEPE_MOCK=true only for local dev without credentials
PHONEPE_MOCK=false
PHONEPE_ENV=production
PHONEPE_MERCHANT_ID=M23IARDYK8WT8
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=
