NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# e.g. your-project.appspot.com — required for venue photo uploads
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App URL — must be your live HTTPS domain in production (PhonePe whitelists this)
# e.g. https://swing-pos.vercel.app — required for payment return redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin — from Firebase Console → Project settings → Service accounts → Generate key (JSON)
# Option A — three vars (recommended on Vercel):
#   FIREBASE_PROJECT_ID = project_id from JSON
#   FIREBASE_CLIENT_EMAIL = client_email from JSON
#   FIREBASE_PRIVATE_KEY = private_key from JSON:
#     • Vercel: paste the full key including -----BEGIN/END----- as multiple lines, OR
#       one line with \n where line breaks are (not double-escaped \\n)
#     • Do not wrap the value in extra quotes
# Option B — single line (easiest on Vercel): FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=

# PhonePe Standard Checkout v2 (Developer Settings on business.phonepe.com)
# Set PHONEPE_MOCK=true only for local dev without credentials
# PHONEPE_ENV=production for live; use sandbox + preprod credentials for testing
# Whitelist your site URL (NEXT_PUBLIC_APP_URL) in PhonePe Business dashboard
PHONEPE_MOCK=false
PHONEPE_ENV=production
PHONEPE_MERCHANT_ID=M23IARDYK8WT8
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=

# Resend — owner email on new customer booking (domain: swing-play.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Swing Play <bookings@swing-play.com>
