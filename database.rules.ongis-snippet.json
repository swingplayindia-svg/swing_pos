{
  "ongis_sports_scoring": {
    ".read": "auth != null",
    ".write": "auth != null && root.child('cmsAdmins').child(auth.uid).val() == true",
    "$sportKey": {
      ".validate": "newData.isBoolean() || (newData.hasChildren(['enabled', 'imageUrl']) && newData.child('enabled').isBoolean() && newData.child('imageUrl').isString())",
      "enabled": {
        ".validate": "newData.isBoolean()"
      },
      "imageUrl": {
        ".validate": "newData.isString() && newData.val().length <= 4096"
      }
    }
  }
}
