rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: anyone authenticated can read (for discovery); write own only
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Matches: participants can read/write
    match /matches/{matchId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.participants;
    }

    // Likes (who liked whom): user writes own; anyone can read (needed for mutual match check)
    match /likes/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Passes (who passed on whom): user can read/write own passes
    match /passes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Received likes (who liked me): user reads own; anyone can write (when they like you)
    match /receivedLikes/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    // Conversations: participants can read/write
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.participants;
    }

    // Proposals (game proposals within a conversation)
    match /conversations/{conversationId}/proposals/{proposalId} {
      allow read, write: if request.auth != null;
    }

    // Invites: sender and recipient can read/write
    match /invites/{inviteId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    // Open matches: public = all read, private = creator only
    match /openMatches/{matchId} {
      allow read: if request.auth != null
        && (resource.data.isPublic == true || resource.data.creatorUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.creatorUid == request.auth.uid;
    }

    // Turfs (venues): authenticated read/write for app + admin CMS
    match /turfs/{turfId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
  }
}
