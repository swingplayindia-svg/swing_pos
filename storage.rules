rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /profile_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /chat_images/{conversationId}/{fileName} {
      function isChatParticipant() {
        let uid = request.auth.uid;
        return conversationId.matches(uid + '_.*')
          || conversationId.matches('.*_' + uid);
      }

      allow read: if request.auth != null && isChatParticipant();

      allow write: if request.auth != null
        && isChatParticipant()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Swing.Play Admin CMS — venue photos (turfs/{folderId}/{timestamp}.ext)
    match /turfs/{folderId}/{allPaths=**} {
      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Swing.Play Admin CMS — Community carousel banners (carousels/community/{slideId}/{timestamp}.ext)
    match /carousels/community/{slideId}/{allPaths=**} {
      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
